# Conforme também analisado na questão anterior (questão (5)) vamos analisar as colunas usando a função (def) para descobrir a média salarial por nivel de experiência e tipo de emprego

# Função para calcular média salarial em dolar por nível de experiência e tipo de emprego
def calcular_media_salarial(df):
    media_salarial = df.groupby(['experience_level', 'employment_type'])['salary_in_usd'].mean().reset_index()
    media_salarial = media_salarial.rename(columns={
        'experience_level': 'nivel_experiencia',
        'employment_type': 'tipo_emprego',
        'salary_in_usd': 'media_salarial_usd'
    })
    return media_salarial

# exibição dos resultados
resultado = calcular_media_salarial(df)
print(resultado)

# Análise dos resultados
def analisar_resultados(resultado):
    for index, row in resultado.iterrows():
        nivel_experiencia = row['nivel_experiencia']
        tipo_emprego = row['tipo_emprego']
        media_salarial = row['media_salarial_usd']
        print(f"Nível de Experiência: {nivel_experiencia}, Tipo de Emprego: {tipo_emprego}, Média Salarial (USD): {media_salarial:.2f}")

analisar_resultados(resultado)


